DATABASE_URL=postgresql://parking:parking@localhost/parking
SESSION_SECRET=change-me-generate-with-python-secrets-module

# Azure AD / Entra ID
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
AZURE_REDIRECT_URI=http://localhost:8000/auth/callback

# Local admin account
# Generate hash: python -c "import bcrypt; print(bcrypt.hashpw(b'your-password', bcrypt.gensalt()).decode())"
# Wrap in single quotes to prevent Docker Compose from expanding $ signs
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=''

# Azure Communication Services
ACS_CONNECTION_STRING=
EMAIL_FROM=parking@alintrust.cz

# App
BASE_URL=http://localhost:8000
RESERVATION_HORIZON_DAYS=31
